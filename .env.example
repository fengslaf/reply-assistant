# 快捷回复助手 - 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ===== 服务配置 =====
SERVER_HOST=localhost
SERVER_PORT=5000
SERVER_DEBUG=true

# ===== 数据库配置 =====
# SQLite 数据库文件路径
DATABASE_PATH=./data/samples.db

# Chroma 向量库持久化路径
VECTOR_STORE_PATH=./data/chroma

# ===== 模型配置 =====
# Embedding 模型路径 (本地运行)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# 大模型配置 (内测期: 用户自带key)
LLM_PROVIDER=deepseek
LLM_API_KEY=sk-your-deepseek-api-key
LLM_API_BASE=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# ===== 微信公众号配置 =====
# 服务号 AppID
WECHAT_APPID=your-wechat-appid

# 服务号 AppSecret
WECHAT_SECRET=your-wechat-secret

# 服务号消息回调 Token
WECHAT_TOKEN=your-wechat-token

# 服务号消息回调 EncodingAESKey
WECHAT_ENCODING_AES_KEY=your-encoding-aes-key

# ===== 安全配置 =====
# API Key 加密密钥 (用于存储用户的模型key)
KEY_ENCRYPTION_SECRET=your-encryption-secret-key

# 管理员 Token
ADMIN_TOKEN=your-admin-token

# ===== 日志配置 =====
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# ===== 其他配置 =====
# 检索时返回的相似样本数量
SEARCH_TOP_K=5

# 生成的候选回复数量
GENERATE_CANDIDATE_COUNT=3